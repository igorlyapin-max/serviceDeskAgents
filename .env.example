COMPOSE_PROJECT_NAME=servicedesk-agents

# PostgreSQL
POSTGRES_DB=servicedesk
POSTGRES_USER=servicedesk
POSTGRES_PASSWORD=servicedesk_dev_password
POSTGRES_PORT=15432

# n8n database
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=n8n_dev_password
N8N_PORT=5678
N8N_ENCRYPTION_KEY=replace_with_32_plus_chars_dev_key
N8N_WEBHOOK_TOKEN=replace_with_dev_webhook_token

# Redis
REDIS_PORT=16379

# LiteLLM
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-dev-litellm-master-key
LITELLM_MODEL_ALIAS=local-opt-125m
LITELLM_UPSTREAM_MODEL=hosted_vllm/facebook/opt-125m

# vLLM CPU
VLLM_PORT=8000
VLLM_MODEL=facebook/opt-125m
VLLM_DTYPE=float32
VLLM_MAX_MODEL_LEN=2048
VLLM_MAX_NUM_SEQS=1
VLLM_CHAT_TEMPLATE=/app/vllm/simple-chat-template.jinja
VLLM_CPU_KVCACHE_SPACE=4
VLLM_CPU_NUM_OF_RESERVED_CPU=1

# Orchestrator
ORCHESTRATOR_PORT=18088

# Integration layer
INTEGRATION_ENDPOINT_PROFILE=mock
N8N_WEBHOOK_BASE_URL=http://127.0.0.1:5678/webhook
ZABBIX_DIRECT_BASE_URL=http://127.0.0.1:8082
CMDB_DIRECT_BASE_URL=http://127.0.0.1:8081
KNOWLEDGE_INDEX_PATH=state/knowledge-index.json
