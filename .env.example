COMPOSE_PROJECT_NAME=servicedesk-agents

# PostgreSQL
POSTGRES_DB=servicedesk
POSTGRES_USER=servicedesk
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_PORT=15432

# n8n database
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me_n8n_db_password
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_32_chars_min
N8N_WEBHOOK_TOKEN=change_me_n8n_webhook_token

# Redis
REDIS_PORT=16379

# Kafka / Redpanda
KAFKA_PORT=19092
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092

# LiteLLM
LITELLM_PORT=4000
LITELLM_MASTER_KEY=change_me_litellm_master_key
MODEL_ACTIVE_PROVIDER=vllm_cpu
LITELLM_MODEL_ALIAS=local-opt-125m
LITELLM_UPSTREAM_MODEL=hosted_vllm/facebook/opt-125m

# OpenAI API backend
# Реальный token задается только в окружении/секретах, не через Admin UI.
OPENAI_API_KEY=
OPENAI_API_KEY_ENV=OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_ALIAS=openai-primary
# Для LiteLLM указываем модель с provider prefix.
OPENAI_MODEL=openai/gpt-4.1-mini
OPENAI_CONTEXT_LENGTH=128000
OPENAI_MAX_TOKENS=4096
OPENAI_REQUESTS_PER_MINUTE=60
OPENAI_TOKENS_PER_MINUTE=120000

# vLLM CPU
VLLM_PORT=8000
VLLM_MODEL=facebook/opt-125m
VLLM_DTYPE=float32
VLLM_MAX_MODEL_LEN=2048
VLLM_MAX_NUM_SEQS=1
VLLM_CHAT_TEMPLATE=/app/vllm/simple-chat-template.jinja
VLLM_CPU_KVCACHE_SPACE=4
VLLM_CPU_NUM_OF_RESERVED_CPU=1

# Orchestrator
APP_ENV=local
ORCHESTRATOR_PORT=18088
SECURITY_AUTH_MODE=dev_header
SECURITY_DEV_ACTOR=admin-1
SECURITY_RATE_LIMIT_PER_MINUTE=600
METRICS_ALLOWED_IPS=127.0.0.1,::1
INTEGRATION_CALLBACK_TOKEN=change_me_integration_callback_token
# Для shared/staging/production используйте source-specific token вместо общего.
INTEGRATION_CALLBACK_TOKEN__N8N=
LOG_LEVEL=INFO
LOG_SINKS=stdout,jsonl
LOG_JSONL_PATH=state/logs/servicedesk-events.jsonl
DEBUG_LOGGING_ENABLED=false
DEBUG_LOGGING_LEVEL=Basic
READYZ_STRICT=false

# Integration layer
INTEGRATION_ENDPOINT_PROFILE=mock
N8N_WEBHOOK_BASE_URL=http://127.0.0.1:5678/webhook
ZABBIX_DIRECT_BASE_URL=http://127.0.0.1:8082
CMDB_DIRECT_BASE_URL=http://127.0.0.1:8081
KNOWLEDGE_INDEX_PATH=state/knowledge-index.json
