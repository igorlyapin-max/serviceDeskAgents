{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/cases/case-event.schema.json",
  "title": "Case Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "case_id",
    "ticket_id",
    "event_type",
    "actor_type",
    "actor_id",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^evt-[a-f0-9]{12}$"
    },
    "case_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^case-[a-f0-9]{12}$"
    },
    "ticket_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "event_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "actor_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ticket_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "action_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "gate_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "invocation_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "endpoint_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "operation_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "feedback_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
