{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/attribute-resolution-profiles.schema.json",
  "title": "Attribute Resolution Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "display_name",
          "status",
          "description",
          "target_slot_id",
          "output_slots",
          "input_attributes",
          "candidate_source",
          "result_policy",
          "decision_policy",
          "clarification_policy",
          "handoff_policy",
          "max_attempts",
          "audit_required",
          "log_required"
        ],
        "properties": {
          "profile_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "active",
              "planned",
              "disabled"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "target_slot_id": {
            "$ref": "#/$defs/id"
          },
          "output_slots": {
            "$ref": "#/$defs/id_list"
          },
          "input_attributes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/input_attribute"
            },
            "uniqueItems": true
          },
          "candidate_source": {
            "$ref": "#/$defs/candidate_source"
          },
          "result_policy": {
            "$ref": "#/$defs/result_policy"
          },
          "decision_policy": {
            "$ref": "#/$defs/decision_policy"
          },
          "clarification_policy": {
            "$ref": "#/$defs/clarification_policy"
          },
          "handoff_policy": {
            "$ref": "#/$defs/handoff_policy"
          },
          "fallback": {
            "$ref": "#/$defs/fallback"
          },
          "confidence_threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "confidence_thresholds": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "auto_fill": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "clarification": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "operator_handoff": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "max_attempts": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "audit_required": {
            "type": "boolean"
          },
          "log_required": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "id_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "source_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "input_attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attribute_id",
        "display_name",
        "source",
        "required"
      ],
      "properties": {
        "attribute_id": {
          "$ref": "#/$defs/id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "source": {
          "type": "string",
          "enum": [
            "ticket_text",
            "slot",
            "case",
            "llm",
            "operator_answer",
            "constant"
          ]
        },
        "source_ref": {
          "$ref": "#/$defs/source_ref"
        },
        "required": {
          "type": "boolean"
        },
        "extraction_instruction": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        }
      }
    },
    "candidate_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "react_call",
            "ticket_history",
            "case_data",
            "disabled"
          ]
        },
        "tool_name": {
          "$ref": "#/$defs/id"
        },
        "endpoint_id": {
          "$ref": "#/$defs/id"
        },
        "operation_id": {
          "$ref": "#/$defs/id"
        },
        "parameter_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^(slot|attribute|constant|secret|case|context):.+$"
          }
        },
        "history_filter": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "result_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_type",
        "target_value_path"
      ],
      "properties": {
        "result_type": {
          "type": "string",
          "enum": [
            "list",
            "object"
          ]
        },
        "list_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "object_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "success_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "target_value_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "display_value_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "confidence_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "output_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "decision_action": {
      "type": "string",
      "enum": [
        "auto_fill_if_confident",
        "ask_clarification",
        "ask_disambiguation",
        "operator_handoff",
        "escalate",
        "leave_empty",
        "debug_stop"
      ]
    },
    "decision_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "empty_result",
        "single_result",
        "multiple_results",
        "source_error",
        "attempt_limit"
      ],
      "properties": {
        "empty_result": {
          "$ref": "#/$defs/decision_action"
        },
        "single_result": {
          "$ref": "#/$defs/decision_action"
        },
        "multiple_results": {
          "$ref": "#/$defs/decision_action"
        },
        "source_error": {
          "$ref": "#/$defs/decision_action"
        },
        "attempt_limit": {
          "$ref": "#/$defs/decision_action"
        }
      }
    },
    "clarification_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "ask_for_attributes"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "ask_for_attributes": {
          "$ref": "#/$defs/id_list"
        }
      }
    },
    "handoff_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "package"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "operator_handoff",
            "escalate",
            "debug_stop",
            "leave_empty"
          ]
        },
        "package": {
          "$ref": "#/$defs/id_list"
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "ask_user",
            "operator_handoff",
            "escalate",
            "leave_empty"
          ]
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        }
      }
    }
  }
}
