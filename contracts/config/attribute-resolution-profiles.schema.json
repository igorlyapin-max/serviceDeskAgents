{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/attribute-resolution-profiles.schema.json",
  "title": "Attribute Resolution Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "display_name",
          "status",
          "description",
          "slot_schema_id",
          "enrichment_steps",
          "llm_resolution_script",
          "human_resolution_policy",
          "max_attempts"
        ],
        "properties": {
          "profile_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "active",
              "planned",
              "disabled"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "slot_schema_id": {
            "$ref": "#/$defs/id"
          },
          "target_slot_id": {
            "$ref": "#/$defs/id"
          },
          "use_llm_after_steps": {
            "type": "boolean",
            "default": true
          },
          "enrichment_steps": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/enrichment_step"
            }
          },
          "output_slots_order": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/output_slot_rule"
            }
          },
          "llm_resolution_script": {
            "$ref": "#/$defs/llm_resolution_script"
          },
          "human_resolution_policy": {
            "$ref": "#/$defs/human_resolution_policy"
          },
          "fallback": {
            "$ref": "#/$defs/fallback"
          },
          "confidence_threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "confidence_thresholds": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "auto_fill": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "clarification": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "operator_handoff": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "max_attempts": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "id_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "source_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "input_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "required_for_operation",
        "can_ask_user"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/id"
        },
        "required_for_operation": {
          "type": "boolean"
        },
        "can_ask_user": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "maxLength": 600
        }
      }
    },
    "enrichment_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_name",
        "step_id",
        "react_call",
        "parameter_mapping",
        "on_error"
      ],
      "properties": {
        "step_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "step_id": {
          "type": "string",
          "minLength": 5,
          "maxLength": 40,
          "pattern": "^step[1-9][0-9]*$"
        },
        "react_call": {
          "$ref": "#/$defs/id"
        },
        "endpoint_id": {
          "$ref": "#/$defs/id"
        },
        "operation_id": {
          "$ref": "#/$defs/id"
        },
        "completion_policy": {
          "$ref": "#/$defs/completion_policy"
        },
        "configuration_instruction": {
          "type": "string",
          "maxLength": 4000
        },
        "generated_structure_metadata": {
          "$ref": "#/$defs/generated_structure_metadata"
        },
        "parameter_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^(slot|output|step|constant|secret):.+$"
          }
        },
        "on_error": {
          "type": "string",
          "enum": [
            "continue_to_llm",
            "stop_and_ask_client",
            "escalate_operator"
          ]
        }
      }
    },
    "completion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "max_wait_seconds",
        "timeout_action"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "sync",
            "external_event",
            "timer_wait"
          ]
        },
        "max_wait_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 604800
        },
        "timeout_action": {
          "type": "string",
          "enum": [
            "resume_agent",
            "escalate_operator",
            "mark_failed"
          ]
        },
        "check_interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "expected_event_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "result_transport": {
          "type": "string",
          "enum": [
            "http_callback",
            "kafka_event",
            "both"
          ]
        },
        "result_topic": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "result_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_id",
        "display_name",
        "field_type"
      ],
      "properties": {
        "field_id": {
          "$ref": "#/$defs/id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "field_type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "object",
            "array",
            "unknown"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 600
        }
      }
    },
    "output_slot_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "order",
        "required_for_success",
        "source_hint",
        "fallback"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/id"
        },
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "required_for_success": {
          "type": "boolean"
        },
        "source_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "fallback": {
          "type": "string",
          "enum": [
            "ask_clarification",
            "operator_handoff",
            "leave_empty"
          ]
        }
      }
    },
    "llm_resolution_script": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_text",
        "response_contract"
      ],
      "properties": {
        "script_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "response_contract": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "human_resolution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "message_template"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "ask_client",
            "escalate_operator"
          ]
        },
        "message_template": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1200
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "ask_user",
            "operator_handoff",
            "escalate",
            "leave_empty"
          ]
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        }
      }
    },
    "generated_structure_metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "generator": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "mode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    }
  }
}
