{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/config-draft.schema.json",
  "title": "Platform Config Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "draft_id",
    "domain",
    "payload",
    "status",
    "created_by",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "draft_id": {
      "type": "string",
      "pattern": "^cfgdraft-[a-f0-9]{12}$"
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "base_version_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "payload": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "valid",
        "invalid",
        "regression_passed",
        "activated"
      ]
    },
    "validation": {
      "type": "object",
      "additionalProperties": true
    },
    "regression": {
      "type": "object",
      "additionalProperties": true
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
