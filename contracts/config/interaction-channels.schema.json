{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/interaction-channels.schema.json",
  "title": "Interaction Channels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "channels"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "channel_id",
          "display_name",
          "mode",
          "description",
          "question_delivery",
          "waiting_policy",
          "incomplete_discussion_action",
          "escalation_action",
          "action_profiles",
          "audit_required",
          "enabled"
        ],
        "properties": {
          "channel_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "mode": {
            "type": "string",
            "enum": [
              "online_interactive",
              "offline_interactive",
              "debug"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "question_delivery": {
            "$ref": "#/$defs/channel_action"
          },
          "waiting_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "first_reminder_after_seconds",
              "discussion_timeout_seconds",
              "sla_elapsed_percent_threshold",
              "on_no_answer"
            ],
            "properties": {
              "first_reminder_after_seconds": {
                "type": "integer",
                "minimum": 0,
                "maximum": 604800
              },
              "discussion_timeout_seconds": {
                "type": "integer",
                "minimum": 0,
                "maximum": 604800
              },
              "sla_elapsed_percent_threshold": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "on_no_answer": {
                "type": "string",
                "enum": [
                  "save_context",
                  "create_draft",
                  "create_work_order",
                  "call_specialist",
                  "debug_stop"
                ]
              }
            }
          },
          "incomplete_discussion_action": {
            "$ref": "#/$defs/channel_action"
          },
          "escalation_action": {
            "$ref": "#/$defs/channel_action"
          },
          "action_profiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "profile_id",
                "display_name",
                "event_type",
                "action"
              ],
              "properties": {
                "profile_id": {
                  "$ref": "#/$defs/id"
                },
                "display_name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                },
                "event_type": {
                  "type": "string",
                  "enum": [
                    "standard_handoff",
                    "no_answer",
                    "major_incident",
                    "policy_blocked",
                    "debug_stop"
                  ]
                },
                "action": {
                  "$ref": "#/$defs/channel_action"
                }
              }
            }
          },
          "audit_required": {
            "type": "boolean"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "channel_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_type"
      ],
      "properties": {
        "action_type": {
          "type": "string",
          "enum": [
            "ask_end_user",
            "ask_operator",
            "show_debug_message",
            "save_context",
            "create_draft",
            "create_work_order",
            "call_specialist",
            "notify_on_call",
            "debug_stop"
          ]
        },
        "tool_name": {
          "$ref": "#/$defs/id"
        },
        "endpoint_id": {
          "$ref": "#/$defs/id"
        },
        "operation_id": {
          "$ref": "#/$defs/id"
        },
        "message_template": {
          "type": "string",
          "maxLength": 2000
        }
      }
    }
  }
}
