{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/n8n-workflow-catalog.schema.json",
  "title": "n8n Workflow Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflows"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "workflow_id",
          "display_name",
          "business_scenario",
          "endpoint_id",
          "enabled",
          "operations"
        ],
        "properties": {
          "workflow_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "business_scenario": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "endpoint_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "callback_endpoint_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "enabled": {
            "type": "boolean"
          },
          "operations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            },
            "uniqueItems": true
          },
          "management": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "restart_supported": {
                "type": "boolean"
              },
              "cancel_supported": {
                "type": "boolean"
              },
              "execution_history_supported": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}
