{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/orchestrator-policy.schema.json",
  "title": "Orchestrator Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policies"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "confidence_defaults": {
      "$ref": "#/$defs/confidence_thresholds"
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_id",
          "display_name",
          "max_iterations",
          "consecutive_tool_errors_to_escalate",
          "stop_conditions",
          "allowed_react_action_groups"
        ],
        "properties": {
          "policy_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "max_iterations": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "consecutive_tool_errors_to_escalate": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "stop_conditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "all_required_slots_filled",
                "tool_success",
                "clarification_required",
                "handoff_required",
                "iteration_limit",
                "consecutive_tool_errors"
              ]
            },
            "uniqueItems": true
          },
          "allowed_react_action_groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "read_diagnostics",
                "knowledge_search",
                "external_status_check",
                "action_preparation",
                "state_changing_actions",
                "communication_handoff"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "$defs": {
    "confidence_thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auto_accept_confidence",
        "clarification_confidence",
        "operator_handoff_confidence",
        "min_extraction_confidence"
      ],
      "properties": {
        "auto_accept_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "clarification_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "operator_handoff_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_extraction_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    }
  }
}
