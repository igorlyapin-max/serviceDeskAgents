{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/orchestrator-policy.schema.json",
  "title": "Orchestrator Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policies"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_id",
          "display_name",
          "max_iterations",
          "consecutive_tool_errors_to_escalate",
          "stop_conditions",
          "allowed_tool_classes"
        ],
        "properties": {
          "policy_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "max_iterations": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "consecutive_tool_errors_to_escalate": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "stop_conditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "user_confirmed_success",
                "waiting_for_user",
                "tool_errors_limit",
                "iteration_limit",
                "low_confidence",
                "major_incident"
              ]
            },
            "uniqueItems": true
          },
          "allowed_tool_classes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "read_only",
                "action"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    }
  }
}
