{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/tool-launch-matrix.schema.json",
  "title": "Tool Launch Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrices"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "matrices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "matrix_id",
          "display_name",
          "launches"
        ],
        "properties": {
          "matrix_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "launches": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "launch_id",
                "tool_name",
                "required_slots",
                "parameter_bindings",
                "execution_level",
                "target_execution_level",
                "endpoint_id",
                "operation_id",
                "risk_level",
                "audit_required",
                "log_required",
                "stop_on_error"
              ],
              "properties": {
                "launch_id": {
                  "$ref": "#/$defs/id"
                },
                "tool_name": {
                  "$ref": "#/$defs/id"
                },
                "required_slots": {
                  "$ref": "#/$defs/id_list"
                },
                "parameter_bindings": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "type": "string",
                    "pattern": "^(slot|constant|secret|case|context):.+$"
                  }
                },
                "execution_level": {
                  "$ref": "#/$defs/execution_level"
                },
                "target_execution_level": {
                  "$ref": "#/$defs/execution_level"
                },
                "approval_role": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 120
                },
                "endpoint_id": {
                  "$ref": "#/$defs/id"
                },
                "operation_id": {
                  "$ref": "#/$defs/id"
                },
                "risk_level": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high",
                    "critical",
                    "blocked"
                  ]
                },
                "audit_required": {
                  "type": "boolean"
                },
                "log_required": {
                  "type": "boolean"
                },
                "stop_on_error": {
                  "type": "boolean"
                },
                "completion_policy": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "mode",
                    "max_wait_seconds",
                    "timeout_action"
                  ],
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": [
                        "sync",
                        "external_event",
                        "timer_wait"
                      ]
                    },
                    "max_wait_seconds": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 604800
                    },
                    "check_interval_seconds": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 604800
                    },
                    "expected_event_type": {
                      "$ref": "#/$defs/id"
                    },
                    "timeout_action": {
                      "type": "string",
                      "enum": [
                        "resume_agent",
                        "escalate_operator",
                        "debug_stop",
                        "mark_failed",
                        "cancel"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "id_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "execution_level": {
      "type": "string",
      "enum": [
        "auto",
        "operator_approval",
        "approver_approval",
        "blocked"
      ]
    }
  }
}
