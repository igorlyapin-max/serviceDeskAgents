{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/decisions/ai-decision.schema.json",
  "title": "AI Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "operator_message"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "decision": {
      "oneOf": [
        {
          "$ref": "#/$defs/answer_proposed"
        },
        {
          "$ref": "#/$defs/clarification_needed"
        },
        {
          "$ref": "#/$defs/escalation_needed"
        },
        {
          "$ref": "#/$defs/action_proposed"
        }
      ]
    },
    "operator_message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "internal_reasoning_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "citations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/citation"
      }
    },
    "proposed_actions": {
      "type": "array",
      "items": {
        "$ref": "../tools/proposed-action.schema.json"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "type": {
                "const": "action_proposed"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "proposed_actions"
        ],
        "properties": {
          "proposed_actions": {
            "minItems": 1
          }
        }
      },
      "else": {
        "properties": {
          "proposed_actions": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "answer_proposed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "summary",
        "confidence"
      ],
      "properties": {
        "type": {
          "const": "answer_proposed"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "clarification_needed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "missing_fields",
        "question",
        "confidence"
      ],
      "properties": {
        "type": {
          "const": "clarification_needed"
        },
        "missing_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "escalation_needed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "summary",
        "reason",
        "confidence"
      ],
      "properties": {
        "type": {
          "const": "escalation_needed"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "target_team": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "action_proposed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "summary",
        "confidence"
      ],
      "properties": {
        "type": {
          "const": "action_proposed"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
