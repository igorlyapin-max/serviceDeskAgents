{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/execution/action-gate-decision.schema.json",
  "title": "Action Gate Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "operator_id"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject"
      ]
    },
    "operator_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "comment": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
