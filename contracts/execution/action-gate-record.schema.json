{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/execution/action-gate-record.schema.json",
  "title": "Action Gate Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_id",
    "ticket_id",
    "action_id",
    "tool_name",
    "gate_type",
    "status",
    "action",
    "policy_result",
    "created_at",
    "updated_at",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "gate_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "ticket_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "action_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "tool_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "gate_type": {
      "type": "string",
      "enum": [
        "operator_approval",
        "auto_policy"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "executing",
        "succeeded",
        "failed",
        "blocked"
      ]
    },
    "action": {
      "$ref": "https://servicedeskagents.local/contracts/tools/proposed-action.schema.json"
    },
    "policy_result": {
      "$ref": "https://servicedeskagents.local/contracts/execution/execution-policy-result.schema.json"
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "actor_type",
        "actor_id",
        "decided_at"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "approved",
            "rejected"
          ]
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "operator",
            "system_policy"
          ]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "comment": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "tool_result": {
      "$ref": "https://servicedeskagents.local/contracts/tools/tool-result.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event",
          "actor_type",
          "actor_id",
          "created_at"
        ],
        "properties": {
          "event": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "actor_type": {
            "type": "string",
            "enum": [
              "operator",
              "system",
              "system_policy"
            ]
          },
          "actor_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
