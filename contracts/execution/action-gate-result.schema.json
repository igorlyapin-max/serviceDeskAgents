{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/execution/action-gate-result.schema.json",
  "title": "Action Gate Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "accepted",
    "gate",
    "workflow_state"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "accepted": {
      "type": "boolean"
    },
    "gate": {
      "$ref": "https://servicedeskagents.local/contracts/execution/action-gate-record.schema.json"
    },
    "workflow_state": {
      "$ref": "https://servicedeskagents.local/contracts/workflow/workflow-state.schema.json"
    },
    "tool_result": {
      "$ref": "https://servicedeskagents.local/contracts/tools/tool-result.schema.json"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
