{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/execution/execution-policy-result.schema.json",
  "title": "Execution Policy Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action_id",
    "tool_name",
    "execution_mode",
    "allowed",
    "approval_required",
    "policy_rule_id",
    "reason"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "action_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "tool_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "manual_only",
        "operator_approval",
        "auto_execute",
        "dry_run",
        "blocked"
      ]
    },
    "allowed": {
      "type": "boolean"
    },
    "approval_required": {
      "type": "boolean"
    },
    "policy_rule_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "auto_execute"
          }
        }
      },
      "then": {
        "properties": {
          "allowed": {
            "const": true
          },
          "approval_required": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "operator_approval"
          }
        }
      },
      "then": {
        "properties": {
          "allowed": {
            "const": true
          },
          "approval_required": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "blocked"
          }
        }
      },
      "then": {
        "properties": {
          "allowed": {
            "const": false
          },
          "approval_required": {
            "const": false
          }
        }
      }
    }
  ]
}
