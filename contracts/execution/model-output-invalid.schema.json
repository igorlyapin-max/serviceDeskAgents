{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/execution/model-output-invalid.schema.json",
  "title": "Model Output Invalid",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_state",
    "can_advance",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "workflow_state": {
      "$ref": "../workflow/workflow-state.schema.json"
    },
    "can_advance": {
      "const": false
    },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
