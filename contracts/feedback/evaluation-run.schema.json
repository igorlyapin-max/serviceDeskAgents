{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/feedback/evaluation-run.schema.json",
  "title": "Evaluation Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "started_at",
    "case_count",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "case_count": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "completed",
        "failed"
      ]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
