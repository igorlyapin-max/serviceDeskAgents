{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/integrations/external-event.schema.json",
  "title": "External Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "case_id",
    "correlation_id",
    "source",
    "event_type",
    "status",
    "received_at",
    "idempotency_key"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "case_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^case-[a-f0-9]{12}$"
    },
    "ticket_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "wait_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^wait-[a-f0-9]{12}$"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "event_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error",
        "timeout",
        "cancelled",
        "progress"
      ]
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "result": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "raw_reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "error"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "error"
        ]
      }
    }
  ]
}
