          "method": "POST",
          "path": "/api/cmdb/object",
          "request_schema": {
            "type": "object",
            "required": [
              "object_ref"
            ],
            "properties": {
              "object_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 10
        }
      }
    },
    {
      "endpoint_id": "queue.known_incidents",
      "adapter_type": "queue",
      "display_name": "Заготовка очереди поиска известных инцидентов",
      "enabled": true,
      "operations": {
        "search_known_incidents": {
          "display_name": "Найти известные инциденты через очередь",
          "description": "Поставить задачу поиска известных инцидентов в очередь.",
          "method": "POST",
          "path": "servicedesk.known-incidents.search",
          "request_schema": {
            "type": "object",
            "required": [
              "query"
            ],
            "properties": {
              "query": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 10
        }
      }
    }
  ]
}
