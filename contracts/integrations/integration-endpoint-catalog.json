{
  "schema_version": "1.0",
  "endpoints": [
    {
      "endpoint_id": "mock.diagnostics",
      "adapter_type": "mock",
      "display_name": "Тестовая точка интеграции диагностики",
      "enabled": true,
      "operations": {
        "check_zabbix_status": {
          "method": "POST",
          "path": "/mock/diagnostics/zabbix-status",
          "timeout_seconds": 5,
          "mock_output": {
            "service_status": "ok",
            "message": "Тестовая диагностика завершена."
          }
        }
      }
    },
    {
      "endpoint_id": "mock.cmdb",
      "adapter_type": "mock",
      "display_name": "Тестовая точка интеграции CMDB",
      "enabled": true,
      "operations": {
        "query_cmdb_object": {
          "method": "POST",
          "path": "/mock/cmdb/query-object",
          "timeout_seconds": 5,
          "mock_output": {
            "object_found": true,
            "message": "Тестовый поиск объекта CMDB завершен."
          }
        }
      }
    },
    {
      "endpoint_id": "mock.ownership",
      "adapter_type": "mock",
      "display_name": "Тестовая точка интеграции владельцев",
      "enabled": true,
      "operations": {
        "get_service_owner": {
          "method": "POST",
          "path": "/mock/ownership/service-owner",
          "timeout_seconds": 5,
          "mock_output": {
            "owner_team": "L2-platform",
            "message": "Тестовый поиск владельца завершен."
          }
        }
      }
    },
    {
      "endpoint_id": "mock.known_incidents",
      "adapter_type": "mock",
      "display_name": "Тестовая точка интеграции известных инцидентов",
      "enabled": true,
      "operations": {
        "search_known_incidents": {
          "method": "POST",
          "path": "/mock/incidents/search",
          "timeout_seconds": 5,
          "mock_output": {
            "matches": [],
            "message": "Тестовый поиск известных инцидентов завершен."
          }
        }
      }
    },
    {
      "endpoint_id": "mock.runbooks",
      "adapter_type": "mock",
      "display_name": "Тестовая точка интеграции ранбуков",
      "enabled": true,
      "operations": {
        "start_systemcenter_runbook": {
          "method": "POST",
          "path": "/mock/runbooks/start",
          "timeout_seconds": 5,
          "mock_output": {
            "runbook_status": "accepted",
            "message": "Тестовый запуск ранбука принят."
          }
        }
      }
    },
    {
      "endpoint_id": "n8n.systemcenter.runbooks",
      "adapter_type": "n8n_webhook",
      "display_name": "n8n webhook ранбуков System Center",
      "enabled": true,
      "base_url": "http://127.0.0.1:5678/webhook",
      "base_url_env": "N8N_WEBHOOK_BASE_URL",
      "auth": {
        "type": "header_token",
        "header_name": "X-ServiceDesk-Token",
        "token_env": "N8N_WEBHOOK_TOKEN"
      },
      "operations": {
        "start_systemcenter_runbook": {
          "method": "POST",
          "path": "/servicedesk/runbook/start",
          "timeout_seconds": 15
        }
      }
    },
    {
      "endpoint_id": "n8n.diagnostics",
      "adapter_type": "n8n_webhook",
      "display_name": "n8n webhook диагностики",
      "enabled": true,
      "base_url": "http://127.0.0.1:5678/webhook",
      "base_url_env": "N8N_WEBHOOK_BASE_URL",
      "auth": {
        "type": "header_token",
        "header_name": "X-ServiceDesk-Token",
        "token_env": "N8N_WEBHOOK_TOKEN"
      },
      "operations": {
        "check_zabbix_status": {
          "method": "POST",
          "path": "/servicedesk/diagnostics/zabbix-status",
          "timeout_seconds": 15
        }
      }
    },
    {
      "endpoint_id": "direct.zabbix.disabled",
      "adapter_type": "direct_http",
      "display_name": "Отключенная заготовка прямого Zabbix API",
      "enabled": false,
      "disabled_reason": "Этап 5 оставляет реальные вызовы Zabbix API вне scope.",
      "base_url": "http://127.0.0.1:8082",
      "base_url_env": "ZABBIX_DIRECT_BASE_URL",
      "auth": {
        "type": "none"
      },
      "operations": {
        "check_zabbix_status": {
          "method": "POST",
          "path": "/api/zabbix/status",
          "timeout_seconds": 10
        }
      }
    },
    {
      "endpoint_id": "direct.cmdb.disabled",
      "adapter_type": "direct_http",
      "display_name": "Отключенная заготовка прямого CMDB API",
      "enabled": false,
      "disabled_reason": "Этап 5 оставляет реальные вызовы CMDB API вне scope.",
      "base_url": "http://127.0.0.1:8081",
      "base_url_env": "CMDB_DIRECT_BASE_URL",
      "auth": {
        "type": "none"
      },
      "operations": {
        "query_cmdb_object": {
          "method": "POST",
          "path": "/api/cmdb/object",
          "timeout_seconds": 10
        }
      }
    },
    {
      "endpoint_id": "queue.known_incidents",
      "adapter_type": "queue",
      "display_name": "Заготовка очереди поиска известных инцидентов",
      "enabled": true,
      "operations": {
        "search_known_incidents": {
          "method": "POST",
          "path": "servicedesk.known-incidents.search",
          "timeout_seconds": 10
        }
      }
    }
  ]
}
