          "display_name": "Проверить статус Zabbix напрямую",
          "description": "Заготовка прямого вызова Zabbix API для проверки статуса сервиса.",
          "method": "POST",
          "path": "/api/zabbix/status",
          "request_schema": {
            "type": "object",
            "required": [
              "target_ref"
            ],
            "properties": {
              "target_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 10
        }
      }
    },
    {
      "endpoint_id": "direct.cmdb.disabled",
      "adapter_type": "direct_http",
      "display_name": "Отключенная заготовка прямого CMDB API",
      "enabled": false,
