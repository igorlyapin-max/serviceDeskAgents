{
  "schema_version": "1.0",
  "endpoints": [
    {
      "endpoint_id": "mock",
      "adapter_type": "mock",
      "display_name": "Тестовое подключение интеграций",
      "enabled": true,
      "operations": {
        "check_zabbix_status": {
          "display_name": "Проверить статус Zabbix",
          "description": "Тестовая операция проверки доступности сервиса через диагностическое подключение.",
          "method": "POST",
          "path": "/mock/diagnostics/zabbix-status",
          "request_schema": {
            "type": "object",
            "required": [
              "target_ref"
            ],
            "properties": {
              "target_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 5,
          "mock_output": {
            "service_status": "ok",
            "message": "Тестовая диагностика завершена."
          }
        },
        "search_ad_users": {
          "display_name": "Найти пользователей AD",
          "description": "Тестовая операция поиска пользователя по логину, ФИО или уточняющим атрибутам.",
          "method": "POST",
          "path": "/mock/identity/search-users",
          "request_schema": {
            "type": "object",
            "properties": {
              "login": {
                "type": "string",
                "minLength": 1
              },
              "last_name": {
                "type": "string",
                "minLength": 1
              },
              "first_name": {
                "type": "string",
                "minLength": 1
              },
              "middle_name": {
                "type": "string",
                "minLength": 1
              },
              "department": {
                "type": "string",
                "minLength": 1
              },
              "employee_number": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 5,
          "mock_output": {
            "candidate_count": 1,
            "users": [
              {
                "login": "ivanov",
                "user_id": "u-1001",
                "display_name": "Иванов Иван",
                "department": "ИТ"
              }
            ],
            "message": "Тестовый поиск пользователя в AD завершен."
          }
        },
        "query_cmdb_object": {
          "display_name": "Запросить объект CMDB",
          "description": "Тестовая операция чтения metadata объекта CMDB.",
          "method": "POST",
          "path": "/mock/cmdb/query-object",
          "request_schema": {
            "type": "object",
            "required": [
              "object_ref"
            ],
            "properties": {
              "object_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 5,
          "mock_output": {
            "object_found": true,
            "message": "Тестовый поиск объекта CMDB завершен."
          }
        },
        "get_service_owner": {
          "display_name": "Получить владельца сервиса",
          "description": "Тестовая операция определения ответственной команды или владельца сервиса.",
          "method": "POST",
          "path": "/mock/ownership/service-owner",
          "request_schema": {
            "type": "object",
            "required": [
              "target_ref"
            ],
            "properties": {
              "target_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 5,
          "mock_output": {
            "owner_team": "L2-platform",
            "message": "Тестовый поиск владельца завершен."
          }
        },
        "search_known_incidents": {
          "display_name": "Найти известные инциденты",
          "description": "Тестовая операция поиска похожих известных инцидентов.",
          "method": "POST",
          "path": "/mock/incidents/search",
          "request_schema": {
            "type": "object",
            "required": [
              "query"
            ],
            "properties": {
              "query": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 5,
          "mock_output": {
            "matches": [],
            "message": "Тестовый поиск известных инцидентов завершен."
          }
        },
        "start_systemcenter_runbook": {
          "display_name": "Запустить ранбук System Center",
          "description": "Тестовая операция принятия запуска ранбука без обращения к реальному System Center.",
          "method": "POST",
          "path": "/mock/runbooks/start",
          "request_schema": {
            "type": "object",
            "required": [
              "runbook_code"
            ],
            "properties": {
              "runbook_code": {
                "title": "Код ранбука",
                "type": "string",
                "minLength": 1
              },
              "login": {
                "title": "Логин пользователя",
                "type": "string",
                "minLength": 1
              },
              "account_type": {
                "title": "Тип учетной записи",
                "type": "string",
                "minLength": 1
              },
              "device_name": {
                "title": "Имя устройства",
                "type": "string",
                "minLength": 1
              },
              "app_name": {
                "title": "Приложение",
                "type": "string",
                "minLength": 1
              },
              "error_text": {
                "title": "Текст ошибки",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 5,
          "mock_output": {
            "runbook_status": "accepted",
            "message": "Тестовый запуск ранбука принят."
          }
        }
      }
    },
    {
      "endpoint_id": "n8n",
      "adapter_type": "n8n_webhook",
      "display_name": "n8n webhook AI ServiceDesk",
      "enabled": true,
      "base_url": "http://127.0.0.1:5678/webhook",
      "base_url_env": "N8N_WEBHOOK_BASE_URL",
      "auth": {
        "type": "header_token",
        "header_name": "X-ServiceDesk-Token",
        "token_env": "N8N_WEBHOOK_TOKEN"
      },
      "operations": {
        "start_systemcenter_runbook": {
          "display_name": "Запустить ранбук System Center",
          "description": "Вызвать n8n webhook запуска ранбука System Center.",
          "method": "POST",
          "path": "/servicedesk/runbook/start",
          "request_schema": {
            "type": "object",
            "required": [
              "runbook_code"
            ],
            "properties": {
              "runbook_code": {
                "title": "Код ранбука",
                "type": "string",
                "minLength": 1
              },
              "login": {
                "title": "Логин пользователя",
                "type": "string",
                "minLength": 1
              },
              "account_type": {
                "title": "Тип учетной записи",
                "type": "string",
                "minLength": 1
              },
              "device_name": {
                "title": "Имя устройства",
                "type": "string",
                "minLength": 1
              },
              "app_name": {
                "title": "Приложение",
                "type": "string",
                "minLength": 1
              },
              "error_text": {
                "title": "Текст ошибки",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 15
        },
        "search_ad_users": {
          "display_name": "Найти пользователей AD",
          "description": "Вызвать n8n webhook поиска пользователя в Active Directory.",
          "method": "POST",
          "path": "/servicedesk/identity/search-users",
          "request_schema": {
            "type": "object",
            "properties": {
              "login": {
                "type": "string",
                "minLength": 1
              },
              "last_name": {
                "type": "string",
                "minLength": 1
              },
              "first_name": {
                "type": "string",
                "minLength": 1
              },
              "middle_name": {
                "type": "string",
                "minLength": 1
              },
              "department": {
                "type": "string",
                "minLength": 1
              },
              "employee_number": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 15
        },
        "check_zabbix_status": {
          "display_name": "Проверить статус Zabbix",
          "description": "Вызвать n8n webhook диагностики статуса сервиса.",
          "method": "POST",
          "path": "/servicedesk/diagnostics/zabbix-status",
          "request_schema": {
            "type": "object",
            "required": [
              "target_ref"
            ],
            "properties": {
              "target_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "timeout_seconds": 15
        }
      }
    },
    {
      "endpoint_id": "direct.zabbix.disabled",
      "adapter_type": "direct_http",
      "display_name": "Отключенная заготовка прямого Zabbix API",
      "enabled": false,
      "disabled_reason": "Этап 5 оставляет реальные вызовы Zabbix API вне scope.",
