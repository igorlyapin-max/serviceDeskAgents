{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/integrations/integration-endpoint.schema.json",
  "title": "Integration Endpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "endpoint_id",
    "adapter_type",
    "enabled",
    "operations"
  ],
  "properties": {
    "endpoint_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "adapter_type": {
      "type": "string",
      "enum": [
        "mock",
        "n8n_webhook",
        "direct_http",
        "queue"
      ]
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "enabled": {
      "type": "boolean"
    },
    "disabled_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "base_url": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "base_url_env": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "auth": {
      "$ref": "#/$defs/auth"
    },
    "contract_source": {
      "$ref": "#/$defs/contract_source"
    },
    "operations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/operation"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "header_token",
            "bearer_token"
          ]
        },
        "header_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "token_env": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "contract_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "enabled",
        "method",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "openapi_3_1"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "description",
        "method",
        "path",
        "request_schema",
        "response_schema",
        "contract_version",
        "contract_status",
        "timeout_seconds"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "request_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "response_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "async_event_contracts": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/async_event_contract"
          }
        },
        "contract_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "contract_status": {
          "type": "string",
          "enum": [
            "draft",
            "valid",
            "broken",
            "deprecated"
          ]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "mock_output": {
          "type": "object",
          "additionalProperties": true
        },
        "mock_examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mock_example"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "mock_example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "example_id",
        "display_name",
        "request_example",
        "response_example",
        "source",
        "sanitized"
      ],
      "properties": {
        "example_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "request_example": {
          "type": "object",
          "additionalProperties": true
        },
        "response_example": {
          "type": "object",
          "additionalProperties": true
        },
        "expected_status": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "source": {
          "type": "string",
          "enum": [
            "manual",
            "captured"
          ]
        },
        "sanitized": {
          "type": "boolean"
        },
        "captured_at": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "captured_from_endpoint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "contract_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      }
    },
    "async_event_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "contract_status",
        "statuses"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "statuses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "success",
              "error",
              "timeout",
              "cancelled",
              "progress"
            ]
          },
          "uniqueItems": true
        },
        "result_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "progress_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "error_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "contract_status": {
          "type": "string",
          "enum": [
            "draft",
            "valid",
            "broken",
            "deprecated"
          ]
        }
      }
    }
  }
}
