{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/knowledge/knowledge-index-manifest.schema.json",
  "title": "Knowledge Index Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "index_id",
    "status",
    "built_at",
    "requested_by_operator",
    "source_count",
    "document_count",
    "chunk_count",
    "sources",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "index_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed"
      ]
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by_operator": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "source_count": {
      "type": "integer",
      "minimum": 0
    },
    "document_count": {
      "type": "integer",
      "minimum": 0
    },
    "chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "status",
          "document_count",
          "chunk_count"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "skipped",
              "error"
            ]
          },
          "document_count": {
            "type": "integer",
            "minimum": 0
          },
          "chunk_count": {
            "type": "integer",
            "minimum": 0
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    }
  }
}
