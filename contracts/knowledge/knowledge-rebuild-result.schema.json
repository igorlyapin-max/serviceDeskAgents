{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/knowledge/knowledge-rebuild-result.schema.json",
  "title": "Knowledge Rebuild Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "index_manifest",
    "index_path"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed"
      ]
    },
    "index_manifest": {
      "$ref": "https://servicedeskagents.local/contracts/knowledge/knowledge-index-manifest.schema.json"
    },
    "index_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
