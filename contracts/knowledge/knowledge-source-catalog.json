      "connector_type": "http_pull",
      "sync_mode": "incremental",
      "base_url_env": "SERVICEDESK_KB_BASE_URL",
      "auth_profile": "servicedesk_kb_readonly",
      "metadata": {}
    },
    {
      "source_id": "cmdb.exports",
      "source_type": "cmdb_export",
      "display_name": "Экспорты CMDB",
      "enabled": false,
      "disabled_reason": "Этап 7 держит загрузку экспортов CMDB как будущий источник, уже описанный в каталоге.",
      "connector_type": "database_export",
      "sync_mode": "full",
      "metadata": {}
    }
  ]
