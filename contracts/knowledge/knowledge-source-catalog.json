      "display_name": "Локальная база знаний для разработки",
      "enabled": true,
      "connector_type": "local_files",
      "sync_mode": "full",
      "path": "knowledge",
      "include_globs": [
        "*.md",
        "*.txt"
      ],
      "metadata": {
        "environment": "dev",
        "labels": [
          "local"
        ]
      }
    },
    {
      "source_id": "corp.wiki",
      "source_type": "wiki",
      "display_name": "Корпоративная wiki",
      "enabled": false,
      "disabled_reason": "Этап 7 определяет заготовку коннектора; живая синхронизация wiki требует URL источника, авторизацию и mapping ACL.",
      "connector_type": "http_pull",
      "sync_mode": "incremental",
      "base_url_env": "CORP_WIKI_BASE_URL",
      "auth_profile": "corp_wiki_readonly",
      "metadata": {
        "requires_acl_mapping": true
      }
    },
    {
      "source_id": "servicedesk.kb",
      "source_type": "servicedesk_kb",
