{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/knowledge/knowledge-source-catalog.schema.json",
  "title": "Knowledge Source Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://servicedeskagents.local/contracts/knowledge/knowledge-source.schema.json"
      }
    }
  }
}
