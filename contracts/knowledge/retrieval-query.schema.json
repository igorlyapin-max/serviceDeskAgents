{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/knowledge/retrieval-query.schema.json",
  "title": "Retrieval Query",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "query"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 3
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "environment": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "uniqueItems": true
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "uniqueItems": true
        }
      }
    }
  }
}
