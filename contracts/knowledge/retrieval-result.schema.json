{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/knowledge/retrieval-result.schema.json",
  "title": "Retrieval Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "query",
    "matches"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "empty",
        "unavailable",
        "error"
      ]
    },
    "query": {
      "$ref": "https://servicedeskagents.local/contracts/knowledge/retrieval-query.schema.json"
    },
    "index_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "document_id",
          "chunk_id",
          "title",
          "uri",
          "score",
          "excerpt",
          "metadata"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "document_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "chunk_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 700
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "uri": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "excerpt": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
