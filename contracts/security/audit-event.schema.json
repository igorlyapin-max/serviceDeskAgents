{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/security/audit-event.schema.json",
  "title": "Audit Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "actor_id",
    "actor_roles",
    "action",
    "resource_type",
    "outcome",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "audit_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^aud-[a-f0-9]{12}$"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "actor_roles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "permission": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_.]*$"
    },
    "resource_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9_.]*$"
    },
    "resource_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success",
        "denied",
        "error"
      ]
    },
    "request_method": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20
    },
    "request_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "status_code": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "ip_address": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
