{
  "schema_version": "1.0",
  "tools": [
    {
      "tool_name": "check_zabbix_status",
      "action_type": "read_only",
      "description": "Получить краткий статус здоровья сервиса из диагностического endpoint Zabbix.",
      "endpoint_bindings": [
        {
          "profile": "mock",
          "endpoint_id": "mock.diagnostics",
          "operation_id": "check_zabbix_status"
        },
        {
          "profile": "n8n",
          "endpoint_id": "n8n.diagnostics",
          "operation_id": "check_zabbix_status"
        },
        {
          "profile": "direct_http",
          "endpoint_id": "direct.zabbix.disabled",
          "operation_id": "check_zabbix_status"
        }
      ],
      "parameters_schema": {
        "type": "object",
        "required": [
          "service_name",
          "environment"
        ],
        "properties": {
          "service_name": {
            "type": "string",
            "minLength": 1
          },
          "environment": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      },
      "result_schema": {
        "type": "object",
        "required": [
          "service_status",
          "message"
        ],
        "properties": {
          "service_status": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      },
      "policy": {
        "default_timeout_seconds": 5,
        "retry": {
          "max_attempts": 1,
          "backoff_seconds": 0
        },
        "allowed_environments": [
          "dev",
          "test",
          "stage",
          "prod"
        ],
        "approval_required_hint": false,
        "auto_execution_eligible": false,
        "max_risk_level": "low"
      }
    },
