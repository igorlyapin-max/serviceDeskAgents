{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/tools/tool-catalog.schema.json",
  "title": "Tool Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tools"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "tool-definition.schema.json"
      }
    }
  }
}
