{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/workflow/workflow-state.schema.json",
  "title": "Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "terminal",
    "can_advance",
    "requires_operator_action"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "terminal": {
      "type": "boolean"
    },
    "can_advance": {
      "type": "boolean"
    },
    "requires_operator_action": {
      "type": "boolean"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
