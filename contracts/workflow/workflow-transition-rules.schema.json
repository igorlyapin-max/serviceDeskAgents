{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/workflow/workflow-transition-rules.schema.json",
  "title": "Workflow Transition Rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "when",
          "state_id"
        ],
        "properties": {
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "decision_type": {
                "type": "string",
                "minLength": 1
              },
              "execution_mode": {
                "type": "string",
                "minLength": 1
              },
              "failure_state": {
                "type": "string",
                "minLength": 1
              },
              "approval_decision": {
                "type": "string",
                "minLength": 1
              },
              "tool_status": {
                "type": "string",
                "minLength": 1
              },
              "gate_status": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "state_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    }
  }
}
